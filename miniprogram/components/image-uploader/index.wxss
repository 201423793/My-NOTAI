.uploader {
  position: relative;
  width: 100%;
  height: 480rpx;
  background: #FAFAFA;
  border: 2rpx dashed var(--border-color);
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.uploading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.upload-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.upload-text {
  font-size: 26rpx;
  color: var(--text-hint);
}

.placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.placeholder-icon {
  font-size: 80rpx;
  color: var(--text-hint);
  font-weight: 300;
  line-height: 1;
}

.placeholder-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.placeholder-hint {
  font-size: 24rpx;
  color: var(--text-hint);
}
