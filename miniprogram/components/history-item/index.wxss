.history-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.item-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #F5F5F5;
}

.item-content {
  flex: 1;
  min-width: 0;
}

.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.item-platform {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.platform-icon {
  width: 28rpx;
  height: 28rpx;
  border-radius: 6rpx;
}

.platform-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.item-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.status-success {
  background: #E8F5E9;
  color: var(--primary-color);
}

.status-failed {
  background: #FFEBEE;
  color: var(--danger-color);
}

.item-date {
  font-size: 24rpx;
  color: var(--text-hint);
}

.item-delete {
  padding: 16rpx;
  margin-left: 8rpx;
}

.delete-icon {
  font-size: 32rpx;
}
