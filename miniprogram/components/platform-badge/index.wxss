.badge {
  display: inline-flex;
  align-items: center;
  background: #F0F8F0;
  border-radius: 32rpx;
  padding: 8rpx 20rpx 8rpx 8rpx;
  gap: 12rpx;
}

.badge-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
}

.badge-name {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--primary-color);
}

.badge-confidence {
  font-size: 20rpx;
  color: var(--text-hint);
  background: rgba(26, 173, 25, 0.1);
  padding: 2rpx 10rpx;
  border-radius: 12rpx;
}
