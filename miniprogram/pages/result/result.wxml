<view class="result-page">
  <!-- 对比区域 -->
  <view class="comparison-card">
    <view class="comparison-header">
      <text class="comparison-title">对比效果</text>
      <platform-badge platform="{{platform}}" />
    </view>

    <view class="comparison-container" bindtouchmove="onTouchMove">
      <!-- 处理后图片（底层） -->
      <image class="comparison-image" src="{{resultUrl}}" mode="aspectFit" />
      <!-- 处理前图片（顶层，裁剪） -->
      <image
        class="comparison-image comparison-overlay"
        src="{{originalUrl}}"
        mode="aspectFit"
        style="clip-path: inset(0 {{100 - sliderPosition}}% 0 0)"
      />
      <!-- 滑块线 -->
      <view class="slider-line" style="left: {{sliderPosition}}%">
        <view class="slider-handle">
          <text class="slider-icon">◀▶</text>
        </view>
      </view>
      <!-- 标签 -->
      <view class="label label-left">原图</view>
      <view class="label label-right">处理后</view>
    </view>

    <view class="slider-control">
      <text class="slider-label">原图</text>
      <slider
        class="slider"
        value="{{sliderPosition}}"
        min="0"
        max="100"
        activeColor="#1AAD19"
        block-size="20"
        bindchange="onSliderChange"
      />
      <text class="slider-label">处理后</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-card">
    <view class="action-row">
      <button class="btn-primary action-btn" bindtap="saveToAlbum">
        保存到相册
      </button>
    </view>
    <view class="action-row sub-actions">
      <button class="btn-outline sub-btn" bindtap="toggleFavorite">
        {{isFavorited ? '取消收藏' : '收藏'}}
      </button>
      <button class="btn-outline sub-btn" open-type="share">
        分享
      </button>
    </view>
    <view class="action-row">
      <button class="btn-outline action-btn" bindtap="processAnother">
        再处理一张
      </button>
    </view>
  </view>
</view>
