.container {
  padding: 32rpx;
  padding-bottom: 120rpx;
}

.header {
  text-align: center;
  padding: 48rpx 0 32rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.upload-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.detection-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.detecting-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.detecting-text {
  font-size: 26rpx;
  color: var(--text-hint);
}

.detection-hint {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 16rpx;
}

.platform-selector {
  width: 100%;
  margin-top: 16rpx;
}

.selector-label {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: 12rpx;
  display: block;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: var(--bg-page);
  border-radius: var(--radius);
  font-size: 28rpx;
  color: var(--text-primary);
}

.picker-arrow {
  font-size: 20rpx;
  color: var(--text-hint);
}

.action-section {
  margin: 32rpx 0;
}

.credits-info {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 16rpx;
}

.platforms-section {
  margin-top: 16rpx;
}

.platform-list {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.platform-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: calc(20% - 20rpx);
}

.platform-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
}

.platform-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
}
