.processing-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 48rpx;
  background: linear-gradient(135deg, #F5F7FA 0%, #E4E9F0 100%);
}

.processing-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 64rpx 48rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.animation-container {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 48rpx;
}

.pulse-ring {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border: 4rpx solid var(--primary-color);
  border-radius: 50%;
  opacity: 0;
  animation: pulse 2s ease-out infinite;
}

.pulse-ring.delay {
  animation-delay: 0.5s;
}

@keyframes pulse {
  0% {
    transform: scale(0.8);
    opacity: 0.8;
  }
  100% {
    transform: scale(1.4);
    opacity: 0;
  }
}

.icon-container {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, var(--primary-color), #2DC100);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.status-text {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 32rpx;
}

.progress-bar-container {
  width: 100%;
  height: 12rpx;
  background: #EEEEEE;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), #2DC100);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

.tips-section {
  margin-top: 48rpx;
  text-align: center;
}

.tip-text {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.tip-sub {
  display: block;
  font-size: 22rpx;
  color: var(--text-hint);
}

.cancel-btn {
  margin-top: 64rpx;
  width: 300rpx;
}
